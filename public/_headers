# Cloudflare Pages headers — replaces staticwebapp.config.json globalHeaders

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://*.razorpay.com https://*.supabase.co wss://*.supabase.co https://*.google.com https://*.google.co.in https://*.google-analytics.com https://*.googletagmanager.com https://*.doubleclick.net https://*.cloudflareinsights.com https://api.ipify.org https://1.1.1.1; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.razorpay.com https://*.googletagmanager.com https://*.google-analytics.com https://*.cloudflareinsights.com; frame-src 'self' https://*.razorpay.com; img-src 'self' data: blob: https://*.razorpay.com https://*.google.com https://*.google.co.in https://*.google-analytics.com https://*.googletagmanager.com https://*.doubleclick.net; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.razorpay.com https://*.google.com https://*.google.co.in https://*.google-analytics.com https://*.googletagmanager.com https://*.doubleclick.net https://api.ipify.org https://1.1.1.1;

# Cache static assets aggressively
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=31536000, immutable

# Never cache index.html — always fresh
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
