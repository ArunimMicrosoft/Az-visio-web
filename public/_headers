# =============================================================
# Cloudflare Pages headers — enterprise security posture
# Tested with: https://securityheaders.com (target grade: A+)
#              https://observatory.mozilla.org (target: A+)
# =============================================================

/*
  # Force HTTPS for 1 year + include subdomains + preload eligible
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Prevent MIME-type sniffing attacks
  X-Content-Type-Options: nosniff

  # Disallow framing from other origins (clickjacking defense)
  X-Frame-Options: DENY

  # Legacy XSS filter (defense in depth — modern browsers ignore)
  X-XSS-Protection: 1; mode=block

  # Send minimal referer info to other origins
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable powerful browser APIs we never use
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(self "https://*.razorpay.com"), usb=(), interest-cohort=()

  # Process isolation hardening
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site

  # Hide implementation details
  X-Powered-By: nothing-to-see
  Server: cloudcanvas

  # Content Security Policy — strict allowlist
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.razorpay.com https://checkout.razorpay.com https://*.googletagmanager.com https://*.google-analytics.com https://*.analytics.google.com https://*.cloudflareinsights.com https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https: ; frame-src 'self' https://*.razorpay.com https://checkout.razorpay.com https://challenges.cloudflare.com; frame-ancestors 'none'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.razorpay.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://*.cloudflareinsights.com https://api.ipify.org https://1.1.1.1 https://prices.azure.com https://corsproxy.io https://challenges.cloudflare.com https://open.er-api.com; object-src 'none'; base-uri 'self'; form-action 'self' https://*.razorpay.com; upgrade-insecure-requests; block-all-mixed-content

# Cache static assets aggressively (immutable hashes from Vite)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/icons/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Never cache index.html — always fresh
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# API endpoints: no cache, stricter CSP
/api/*
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

# Hide sourcemaps, dotfiles, env from being served
/.env
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store
