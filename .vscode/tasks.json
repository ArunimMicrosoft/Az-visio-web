{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build: Production",
			"type": "shell",
			"command": "npm run build",
			"group": "build",
			"problemMatcher": ["$tsc"],
			"isBackground": false
		},
		{
			"label": "Dev Server",
			"type": "shell",
			"command": "npm run dev",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Deploy: Commit & Push to main",
			"type": "shell",
			"command": "powershell -ExecutionPolicy Bypass -File deploy.ps1",
			"group": "build",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Git: Status",
			"type": "shell",
			"command": "git status",
			"group": "build",
			"isBackground": false,
			"problemMatcher": []
		}
	]
}